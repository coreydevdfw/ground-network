rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────
    // Added 2026-07-14 for the admin/master-page tier. Everything else in
    // this file (employers, jobPostings, applications) is the EXISTING
    // production ruleset — pulled directly from the Firebase console
    // (last published 2026-07-06) rather than rewritten from scratch, so
    // none of its validation gets weakened. See the bottom of this file
    // for what changed vs. what stayed the same.
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── admins ───────────────────────────────────────────────────────────
    // Doc ID == Firebase Auth UID of the admin. A signed-in user may read
    // ONLY their own doc (so the client can self-check "am I admin" to
    // decide whether to show the admin page). No client write path at
    // all, by design — bootstrap the first admin by hand in the Firebase
    // console: Firestore > Data > admins > add doc, doc ID = your UID.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── employers ────────────────────────────────────────────────────────
    // Unchanged from production except the `delete` line (see comment).
    match /employers/{employerId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == employerId
        && request.resource.data.get('verified', false) == false
        && request.resource.data.get('vouchedBy', []).size() == 0;
      allow update: if isAdmin() || (request.auth != null && (
        (request.auth.uid == employerId
          && request.resource.data.get('verified', resource.data.get('verified', false)) == resource.data.get('verified', false)
          && request.resource.data.get('vouchedBy', resource.data.get('vouchedBy', [])) == resource.data.get('vouchedBy', []))
        ||
        (request.auth.uid != employerId
          && !(request.auth.uid in resource.data.get('vouchedBy', []))
          && request.resource.data.vouchedBy == resource.data.get('vouchedBy', []).concat([request.auth.uid])
          && request.resource.data.verified == (request.resource.data.vouchedBy.size() >= 2)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['vouchedBy','verified']))
      ));
      // Was `if false` in production (nobody could delete an employer doc
      // at all). Admin-only delete now supports the account/data-deletion
      // backlog item in LEGAL_AND_BUSINESS.md. Employers still can't
      // self-delete — that needs a Cloud Function to also clean up owned
      // jobPostings/applications, not a raw client-side delete.
      allow delete: if isAdmin();
    }

    // ── jobPostings ──────────────────────────────────────────────────────
    // Unchanged from production except admin is now also allowed to
    // update/delete any posting (moderation), alongside the owning
    // employer.
    match /jobPostings/{postingId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.employerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (request.auth != null && resource.data.employerId == request.auth.uid);
    }

    // ── applications ─────────────────────────────────────────────────────
    // Unchanged from production except `list`/`update` also allow admin,
    // and `delete` moves from always-false to admin-only (see comment).
    match /applications/{applicationId} {
      allow get: if true; // status-check link (?application=<id>), no login
      allow list: if isAdmin()
        || (request.auth != null && request.auth.uid == resource.data.employerId);
      allow create: if request.resource.data.keys().hasAll(['postingId','employerId','applicantName','applicantEmail','status'])
        && request.resource.data.status == 'applied';
      allow update: if isAdmin()
        || (request.auth != null && request.auth.uid == resource.data.employerId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','updatedAt']));
      // Was `if false` in production. Admin-only delete supports the
      // account/data-deletion backlog item (deleting an applicant's PII
      // on request).
      allow delete: if isAdmin();
    }
  }
}

// ─────────────────────────────────────────────────────────────────────────
// How this file came together (2026-07-14):
//
// The first draft of this file was written from PROJECT_STATE.md/
// LEGAL_AND_BUSINESS.md descriptions plus a GitHub code search of
// index.html, without having seen the actual rules already live in the
// Firebase console. Before publishing, I opened the console directly
// (project: ground-network, Firestore > Rules, last published 2026-07-06
// 11:31 AM) and found the real production rules were more precise than
// my draft in ways worth keeping:
//   - `verified` is derived (`vouchedBy.size() >= 2`), not just
//     "allowed to change alongside vouchedBy" — blocks a client from
//     setting verified=true without actually reaching the threshold.
//   - The vouch update explicitly blocks an employer vouching twice
//     (`!(request.auth.uid in resource.data.vouchedBy)`) — my draft's
//     concat-equality check didn't stop a duplicate self-vouch.
//   - `applications.create` validates required fields
//     (postingId/employerId/applicantName/applicantEmail/status) and
//     pins status to 'applied' — my draft allowed `create: if true`
//     with no field validation at all.
// Rather than publish my weaker draft over the stronger production
// rules, this file now uses the real production rules as the base and
// adds only the admin/master-page layer on top (the `admins` collection,
// `isAdmin()`, and `|| isAdmin()` added to the specific allow clauses
// noted above). Three `delete` rules move from always-`false` to
// admin-only, which is a deliberate new capability for the master page,
// not an accidental loosening.
//
// Bootstrap after publishing: add one doc under /admins with your own
// Firebase Auth UID as the doc ID, done by hand in the console. No code
// change needed for that step.
